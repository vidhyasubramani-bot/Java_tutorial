package day5;

import java.util.*;

public class largestdigit {
    public static void main(String[]args){
        Scanner input=new Scanner(System.in);
        System.out.println("enter a value:");
        int a=input.nextInt();
        int max=0;

        while(a!=0)
        {
            int pop=a%10;
            if(pop>max)
            {
                max=pop;
            }

            a=a/10;
        }
        System.out.println("the largest number is:"+max);

    }
}


