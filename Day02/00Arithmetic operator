import java.util.*;
public class arithmetic{
    public static void main(String[]args){
        Scanner input=new Scanner(System.in);
        System.out.println("enter a number:");
        int a=input.nextInt();
        System.out.println("Enter a number:");
        int b =input.nextInt();
        int c=a+b;

        System.out.println("Addition of two values:"+c);
        c=0;
        c=a-b;
        System.out.println("Sub:"+c);
        c=0;
        c=a*b;

        System.out.println("Multiplication of two values:"+c);
        c=0;
        c=a/b;

        System.out.println("Division of two values:"+c);
        c=0;
        c=a++;
        System.out.println("increment of two values:"+c);
        c=0;
        c=a--;
        System.out.println("decrement of two values:"+c);
    }
}
