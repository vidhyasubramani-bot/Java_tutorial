package day6;
import java.util.*;
public class inverted_rightangle_triangle {
    public static void main(String[]args){
        Scanner input=new Scanner(System.in);
        int a=input.nextInt();
        for(int i=0;i<a;i++)
        {
            for(int j=a;j>i;j--)
            {
                System.out.print("*");
            }
            System.out.println();
        }
    }
}
