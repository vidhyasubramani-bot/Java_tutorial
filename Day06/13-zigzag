package day6;
import java.security.spec.RSAOtherPrimeInfo;
import java.util.*;
public class zigzag {
    public static void main(String[]args){
        Scanner input=new Scanner(System.in);

        for(int i=0;i<=5;i++){
            int num=i;
            for(int j=0;j<=5;j++){
                System.out.print(num +" ");
                num=num+5-j;
            }
            System.out.println();
        }
    }
}
