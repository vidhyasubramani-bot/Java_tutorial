package day6;
import java.util.*;
public class multiplication {
    public static void main(String[]args){
        Scanner input=new Scanner(System.in);
        int a=input.nextInt();
        for(int i=1;i<=5;i++){
            for(int j=1;j<=5;j++){
                System.out.printf("%4d",i*j);
            }
            System.out.println();
        }
    }
}
