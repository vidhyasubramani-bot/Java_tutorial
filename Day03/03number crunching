
package day3;

import java.util.*;

public class numbercrunching {

    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

        System.out.println("Enter a value:");
        int a = input.nextInt();

        if (a > 0) {
            System.out.println("Positive");
        } else {
            System.out.println("Negative");
        }

        input.close();
    }
}
